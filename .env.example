# =========================================================================
#  Configuração da aplicação — copie para `.env.local` (dev) ou `.env`
# =========================================================================

# URL pública canônica do site (sem barra no final).
# Usada para montar as tags <link rel="canonical"> e o sitemap.
NEXT_PUBLIC_SITE_URL=https://www.horariodeonibusdf.com.br

# -------------------------------------------------------------------------
#  API externa de dados de ônibus (consumida apenas no servidor)
# -------------------------------------------------------------------------

# URL base da API (sem barra no final). Ex.: https://api.exemplo.com
API_BASE_URL=https://api.exemplo.com

# Credenciais usadas no endpoint POST /api/auth
API_EMAIL=usuario@exemplo.com
API_PASSWORD=sua-senha-secreta

# (Opcional) Tempo, em segundos, de antecedência para renovar o token
# antes de expirar. Padrão: 60 segundos.
API_TOKEN_REFRESH_SKEW_SECONDS=60

# -------------------------------------------------------------------------
#  Marketing / Tracking (públicos — expostos ao cliente)
# -------------------------------------------------------------------------

# ID de medição do Google Analytics 4 (ex.: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ID do cliente do Google AdSense (ex.: ca-pub-0000000000000000)
NEXT_PUBLIC_ADSENSE_CLIENT=
